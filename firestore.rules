rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: devices
    // Document ID: deviceId
    // Fields:
    //   - id: string (required)
    //   - serialNumber: string (required)
    //   - shelfTag: string (required)
    //   - type: string (required)
    //   - brand: string (required)
    //   - model: string (required)
    //   - location: string (required)
    //   - status: string (required)
    //   - area: string (required)
    //   - sector: string (required)
    //   - piso: string (required)
    //   - puesto: string (required)
    //   - attachments: list (optional)
    //   - logs: list (optional)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - id: string (required)
    //   - username: string (required)
    //   - role: string (required) - 'Administrador' or 'Usuario'
    //   - fullName: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrador' ||
         request.auth.token.email == "slongojulian@gmail.com");
    }

    function isValidDevice(data) {
      return data.keys().hasAll(['id', 'serialNumber', 'shelfTag', 'type', 'brand', 'model', 'location', 'status', 'area', 'sector', 'piso', 'puesto']) &&
             data.id is string &&
             data.serialNumber is string &&
             data.shelfTag is string &&
             data.type is string &&
             data.brand is string &&
             data.model is string &&
             data.location is string &&
             data.status is string &&
             data.area is string &&
             data.sector is string &&
             data.piso is string &&
             data.puesto is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'role', 'fullName']) &&
             data.id is string &&
             data.username is string &&
             data.role in ['Administrador', 'Usuario'] &&
             data.fullName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /devices/{deviceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidDevice(request.resource.data);
      allow update: if isAuthenticated() && isValidDevice(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
